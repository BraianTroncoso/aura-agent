# Aura — copy to .env and fill in what you use. Never commit the real .env.

# ── Database ──────────────────────────────────────────────────────────────────
# Local: SQLite (default). Cloud: a free Neon/Supabase Postgres URL works as-is
# (sslmode in the URL is handled automatically):
DATABASE_URL=sqlite:///./aura.db
# DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/db?sslmode=require

# ── Brain: local Ollama (no key, no cost) ─────────────────────────────────────
# Aura's chat handler talks to the LLM gateway in this mode:
AURA_LLM_MODE=api
AURA_API_PROVIDER=ollama
AURA_API_MODEL=qwen2.5:3b-instruct
OLLAMA_BASE_URL=http://localhost:11434
# Helper service (llm_service.complete) provider — keep in sync if you use it:
LLM_PROVIDER=ollama

# To use a hosted model instead of Ollama, set e.g.:
#   AURA_API_PROVIDER=gemini     +  GEMINI_API_KEY=...   (free tier, no card)
#   AURA_API_PROVIDER=anthropic  +  ANTHROPIC_API_KEY=...
#   AURA_API_PROVIDER=openai     +  OPENAI_API_KEY=...
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ── Telegram (the chat interface) ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=          # from @BotFather; empty = Telegram disabled
# Receive mode: polling (local) — set to false to use the /telegram/webhook route (hosted).
TELEGRAM_POLLING_ENABLED=true
# Optional shared secret for the webhook route (pass the same value to setWebhook).
# TELEGRAM_WEBHOOK_SECRET=
# Optional Bot API proxy. Needed on hosts that block outbound api.telegram.org
# (e.g. Hugging Face Spaces) — point it at a Cloudflare Worker that forwards to Telegram.
# TELEGRAM_API_BASE=https://your-worker.your-subdomain.workers.dev

# ── Gmail (read via IMAP + send via SMTP, using a Gmail App Password) ──────────
# Create an App Password at https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
